{
  "name": "interactive-story-game-desktop",
  "version": "0.1.0",
  "description": "互动故事游戏 - 桌面版",
  "main": "dist/main/index.js",
  "author": "jflyang",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "dev": "npm run build:main && electron .",
    "package": "npm run build:main && electron-builder --win",
    "package:mac": "npm run build:main && electron-builder --mac",
    "package:linux": "npm run build:main && electron-builder --linux"
  },
  "dependencies": {
    "get-port": "^7.1.0"
  },
  "devDependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "electron": "34.5.8",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.jflyang.interactive-story-game",
    "productName": "互动故事游戏",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../api/dist",
        "to": "api",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/dist",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../data/task-packages",
        "to": "data/task-packages",
        "filter": [
          "**/*",
          "!**/saves/**"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "互动故事游戏"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "resources/icon.png"
    }
  }
}
