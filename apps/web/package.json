    "pinyin-pro": "^3.28.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
